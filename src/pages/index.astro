---
import Layout from "../layouts/Layout.astro";
import UploadForm from "../components/UploadForm.astro";
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
);

const { data: roasts } = await supabase
  .from("roasts")
  .select("*")
  .lt("reports", 3)
  .order("created_at", { ascending: false });

const topRoasts = roasts
  ? [...roasts]
      .sort((a, b) => (b.votes_count || 0) - (a.votes_count || 0))
      .slice(0, 6)
  : [];
---

<Layout title="Daily Trash | 🔥">
  <div
    class="min-h-screen bg-[#0a0a0a] text-white selection:bg-orange-500/30 overflow-x-hidden"
  >
    {
      topRoasts.length > 0 && (
        <section class="relative py-8 overflow-hidden border-b border-white/5 bg-black/40 backdrop-blur-sm">
          <div class="flex items-center gap-4 mb-4 px-8">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75" />
              <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500" />
            </span>
            <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-orange-500">
              Hall of Shame Live
            </h2>
          </div>

          <div class="flex overflow-hidden group">
            <div class="animate-marquee flex gap-6 px-6">
              {[...topRoasts, ...topRoasts].map((top) => (
                <a href={`/roast/${top.id}`} class="flex-none w-64 group/item">
                  <div class="relative aspect-video rounded-2xl overflow-hidden border border-white/10 group-hover/item:border-orange-500 transition-all duration-500">
                    <img
                      src={top.image_url}
                      alt={top.title}
                      class="w-full h-full object-cover opacity-50 group-hover/item:opacity-100 transition-all duration-700"
                    />
                    <div class="absolute bottom-3 left-3 right-3">
                      <p class="text-[10px] font-bold text-orange-500 uppercase italic mb-1">
                        {top.votes_count || 0} Votos
                      </p>
                      <p class="text-xs font-black truncate uppercase tracking-tighter">
                        {top.title}
                      </p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <main class="max-w-6xl mx-auto px-4 py-12">
      <header class="text-center mb-8 space-y-6">
        <h1
          class="text-6xl md:text-8xl font-black tracking-tighter italic uppercase"
        >
          Daily <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-yellow-400"
            >Roast</span
          >
        </h1>

        <div class="flex flex-wrap justify-center gap-4 pt-4">
          <button
            class="px-8 py-3 rounded-full bg-orange-500 text-black font-black uppercase tracking-tighter text-sm"
          >
            🔥 Recientes
          </button>
          <a
            href="/ranking"
            class="px-8 py-3 rounded-full bg-white/5 border border-white/10 text-white font-black uppercase tracking-tighter text-sm hover:bg-white/10 transition-all"
          >
            🏆 Top Ranking
          </a>
        </div>
      </header>

      <div
        class="flex flex-col items-center gap-1 mb-12 animate-bounce opacity-80"
      >
        <span class="text-orange-500 text-2xl font-black">↓</span>
      </div>

      <section class="mb-24">
        <UploadForm />
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          roasts?.map((roast) => (
            <div class="group relative bg-[#111] border border-white/5 rounded-3xl overflow-hidden hover:border-orange-500/50 transition-all duration-500 hover:-translate-y-2">
              <a
                href={`/roast/${roast.id}`}
                class="block aspect-[4/5] overflow-hidden"
              >
                <img
                  src={roast.image_url}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-70 group-hover:opacity-100"
                />
              </a>
              <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black via-black/90 to-transparent">
                <h3 class="text-xl font-bold mb-4 line-clamp-1 uppercase italic tracking-tight">
                  {roast.title}
                </h3>
                <div class="flex items-center justify-between">
                  <button
                    class="vote-btn flex items-center gap-2 px-4 py-2 rounded-xl bg-white/10 hover:bg-orange-500 hover:text-black transition-all font-bold text-sm"
                    data-id={roast.id}
                    data-votes={roast.votes_count || 0}
                  >
                    <span class="text-lg">💀</span>
                    <span class="count-label">{roast.votes_count || 0}</span>
                  </button>
                  <span class="text-[10px] text-gray-500 font-mono uppercase">
                    {new Date(roast.created_at).toLocaleDateString()}
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </main>
  </div>
</Layout>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const voteButtons = document.querySelectorAll(".vote-btn");

  voteButtons.forEach((btn) => {
    const id = btn.getAttribute("data-id");
    if (localStorage.getItem(`voted-${id}`)) {
      btn.classList.add("bg-orange-500", "text-black");
    }
  });

  voteButtons.forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute("data-id");
      const label = target.querySelector(".count-label");
      let currentVotes = parseInt(target.getAttribute("data-votes") || "0");

      const hasVoted = localStorage.getItem(`voted-${id}`);
      const newVotes = hasVoted ? currentVotes - 1 : currentVotes + 1;

      if (label) label.textContent = newVotes.toString();
      target.setAttribute("data-votes", newVotes.toString());

      if (hasVoted) {
        localStorage.removeItem(`voted-${id}`);
        target.classList.remove("bg-orange-500", "text-black");
      } else {
        localStorage.setItem(`voted-${id}`, "true");
        target.classList.add("bg-orange-500", "text-black");
      }

      await supabase
        .from("roasts")
        .update({ votes_count: newVotes })
        .eq("id", id);
    });
  });
</script>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  .group:hover .animate-marquee {
    animation-play-state: paused;
  }
</style>
