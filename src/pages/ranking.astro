---
import Layout from "../layouts/Layout.astro";
import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
);

// Traemos los datos ordenados por votos para el Ranking
const { data: topRoasts } = await supabase
  .from("roasts")
  .select("*")
  .lt("reports", 3)
  .order("votes_count", { ascending: false });
---

<Layout title="Top Ranking | 🔥">
  <div class="min-h-screen bg-[#0a0a0a] text-white selection:bg-orange-500/30">
    <div
      class="fixed top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-orange-600/5 blur-[120px] -z-10"
    >
    </div>

    <main class="max-w-6xl mx-auto px-4 py-12">
      <header class="mb-12">
        <a
          href="/"
          class="text-orange-500 font-bold uppercase text-[10px] tracking-[0.2em] hover:text-white transition-colors flex items-center gap-2"
        >
          <span>←</span> Volver al inicio
        </a>
        <h1
          class="text-5xl md:text-6xl font-black italic uppercase mt-6 tracking-tighter"
        >
          Hall of <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-yellow-400"
            >Shame</span
          >
        </h1>
        <p
          class="text-gray-500 text-sm mt-2 uppercase tracking-widest font-bold"
        >
          Los desastres más votados por la comunidad
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          topRoasts?.map((roast, i) => (
            <div class="relative group bg-[#111] border border-white/5 rounded-3xl overflow-hidden hover:border-orange-500/50 transition-all duration-500 hover:-translate-y-2">
              <div class="absolute top-4 left-4 z-10 bg-orange-500 text-black font-black px-4 py-1 rounded-full shadow-2xl scale-110 -rotate-3 group-hover:rotate-0 transition-transform">
                #{i + 1}
              </div>

              <a
                href={`/roast/${roast.id}`}
                class="block aspect-[4/5] overflow-hidden"
              >
                <img
                  src={roast.image_url}
                  alt={roast.title}
                  class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700"
                />
              </a>

              <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black via-black/90 to-transparent">
                <h3 class="font-black uppercase italic truncate text-xl tracking-tight mb-4 text-center">
                  {roast.title}
                </h3>

                <div class="flex justify-center">
                  <button
                    class="vote-btn flex items-center gap-2 px-6 py-2 rounded-xl bg-white/10 hover:bg-orange-500 hover:text-black transition-all font-bold text-sm active:scale-90"
                    data-id={roast.id}
                    data-votes={roast.votes_count || 0}
                  >
                    <span class="text-lg">💀</span>
                    <span class="count-label">{roast.votes_count || 0}</span>
                  </button>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </main>
  </div>
</Layout>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const voteButtons = document.querySelectorAll(".vote-btn");

  // Verificar votos previos en localStorage
  voteButtons.forEach((btn) => {
    const id = btn.getAttribute("data-id");
    if (localStorage.getItem(`voted-${id}`)) {
      btn.classList.add("bg-orange-500", "text-black");
      btn.classList.remove("bg-white/10");
    }
  });

  voteButtons.forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.getAttribute("data-id");
      const label = target.querySelector(".count-label");
      let currentVotes = parseInt(target.getAttribute("data-votes") || "0");

      const hasVoted = localStorage.getItem(`voted-${id}`);
      const newVotes = hasVoted ? currentVotes - 1 : currentVotes + 1;

      // Actualización Visual inmediata
      if (label) label.textContent = newVotes.toString();
      target.setAttribute("data-votes", newVotes.toString());

      if (hasVoted) {
        localStorage.removeItem(`voted-${id}`);
        target.classList.remove("bg-orange-500", "text-black");
        target.classList.add("bg-white/10");
      } else {
        localStorage.setItem(`voted-${id}`, "true");
        target.classList.add("bg-orange-500", "text-black");
        target.classList.remove("bg-white/10");
      }

      // Guardar en Supabase
      await supabase
        .from("roasts")
        .update({ votes_count: newVotes })
        .eq("id", id);
    });
  });
</script>

<style>
  .truncate {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
